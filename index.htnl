  function renderWorkout(goal, gender, days) {
    const pool = getWorkoutPool(currentLang);
    let plan = pool[goal];

    // build a plan that respects the chosen number of training days
    let selected;
    if (days <= plan.length) {
      selected = plan.slice(0, days);
    } else {
      // repeat/cycle through the pool if user wants more days than the base template has
      selected = [];
      for (let i = 0; i < days; i++) selected.push(plan[i % plan.length]);
    }

    let html = '';
    selected.forEach((day, i) => {
      html += `
        <div class="workout-day">
          <div class="workout-header">
            <span class="workout-day-icon">${day.icon}</span>
            <div class="workout-day-info">
              <div class="workout-day-name">${day.day} — ${day.name}</div>
              <div class="workout-day-focus">${day.focus}</div>
            </div>
            <span class="workout-badge">${day.badge}</span>
          </div>
          <div class="exercises-list">`;
      day.exercises.forEach((ex, j) => {
        html += `
          <div class="exercise-item">
            <span class="ex-num">${j+1}</span>
            <div class="ex-info">
              <div class="ex-name">${ex.n}</div>
              <div class="ex-detail">${ex.d}</div>
            </div>
            <span class="ex-sets">${ex.sets}</span>
          </div>`;
      });
      html += `</div></div>`;
    });

    document.getElementById('workoutContainer').innerHTML = html;
  }

