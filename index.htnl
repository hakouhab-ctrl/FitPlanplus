          { icon:'😴', t:'النوم = بناء العضلات', d:'عضلاتك تنمو أثناء النوم لا أثناء التمرين. احرص على 8-9 ساعات نوم عميق' },
          { icon:'🏥', t:'تجنب الإصابات', d:'الشكل الصحيح أهم من الوزن الثقيل. إصابة واحدة تعيدك أسابيع للوراء' },
