          { icon:'💪', t:'Stay Consistent', d:"Results appear after 3-4 weeks. Consistency beats perfection — one bad day doesn't ruin a good week" }
        ],
        gain: [
          { icon:'🍽️', t:'Eat More Than You Feel', d:'To build muscle you must eat above your energy needs — even if not hungry, eat' },
          { icon:'🥩', t:'Protein After Workout', d:'Eat a protein meal within 45 minutes of finishing your workout for maximum muscle building' },
