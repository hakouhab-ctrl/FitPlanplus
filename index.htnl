          { icon:'🍌', t:'Carbs Around Training', d:'Eat carbs 1 hour before training — they provide explosive energy for a better session' }
        ],
        tone: [
          { icon:'⚡', t:'Controlled Speed', d:'Performing exercises at controlled speed (2 sec up, 3 sec down) doubles the toning effect' },
          { icon:'🔁', t:'Switch Exercises', d:'Change exercise order every two weeks to create muscle shock and avoid plateaus' },
          { icon:'🫁', t:'Proper Breathing', d:'Exhale on effort, inhale on release — improves performance and protects from injury' },
          { icon:'💧', t:'Water & Electrolytes', d:'Drink enough water and eat potassium-rich foods to avoid muscle cramps' },
          { icon:'🌿', t:'Anti-Inflammatory Foods', d:'Turmeric, ginger, berries, fatty fish — reduce post-workout inflammation' },
          { icon:'🧘', t:'Rest Days Are Sacred', d:'Muscles need 48 hours to recover. Active rest accelerates growth, not slows it' }
        ],
        maint: [
          { icon:'⚖️', t:"Balance, Don't Deprive", d:"Maintenance means moderation — one celebratory meal per week won't hurt" },
          { icon:'🧠', t:'Mindful Eating', d:'Eat slowly without screens — gives your brain time to send the fullness signal' },
          { icon:'📅', t:'Regular Training', d:'3-4 training days per week is enough to maintain. Consistency beats intensity' },
          { icon:'🔬', t:'Regular Check-In', d:'Monitor your weight weekly at the same time (right after waking) and track the average' }
        ]
      }
    };

    const tips = allTips[currentLang][goal];
    let html = '';
    tips.forEach(tip => {
      html += `
        <div class="tip-card">
          <span class="tip-icon">${tip.icon}</span>
          <div>
            <div class="tip-title">${tip.t}</div>
            <div class="tip-text">${tip.d}</div>
          </div>
        </div>`;
    });
    document.getElementById('tipsContainer').innerHTML = html;
  }

