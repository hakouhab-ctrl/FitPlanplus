<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FitPlan Pro | Your Personal Nutrition & Workout Plan</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0e1a;
    --surface: #111827;
    --card: #1a2235;
    --border: #1f2d45;
    --accent: #00e5a0;
    --accent2: #0097ff;
    --accent3: #ff6b35;
    --text: #e8edf5;
    --muted: #6b7a99;
    --danger: #ff4560;
    --success: #00e5a0;
    --gold: #ffd700;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  html[dir="rtl"] body { font-family: 'Tajawal', sans-serif; }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 20% 10%, rgba(0,229,160,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 80% 80%, rgba(0,151,255,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 40% 30% at 60% 30%, rgba(255,107,53,0.04) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  /* ===== LANG TOGGLE ===== */
  .lang-toggle {
    position: fixed;
    top: 18px;
    right: 18px;
    z-index: 999;
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 50px;
    padding: 8px 18px;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 7px;
    transition: all 0.2s;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }
  .lang-toggle:hover { border-color: var(--accent); color: var(--accent); }
  html[dir="rtl"] .lang-toggle { right: auto; left: 18px; }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px 20px;
  }

  .logo {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  html[dir="rtl"] .logo { font-family: 'Tajawal', sans-serif; }

  .logo-icon { font-size: 24px; }

  .hero h1 {
    font-family: 'Inter', sans-serif;
    font-size: clamp(42px, 8vw, 90px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 20px;
    background: linear-gradient(135deg, #fff 0%, var(--accent) 50%, var(--accent2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  html[dir="rtl"] .hero h1 { font-family: 'Tajawal', sans-serif; }

  .hero p {
    font-size: clamp(16px, 2.5vw, 20px);
    color: var(--muted);
    max-width: 540px;
    line-height: 1.8;
    margin-bottom: 50px;
  }

  .cta-btn {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #000;
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 700;
    border: none;
    padding: 18px 52px;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 0 40px rgba(0,229,160,0.3);
    animation: pulse-glow 2.5s ease-in-out infinite;
  }
  html[dir="rtl"] .cta-btn { font-family: 'Tajawal', sans-serif; }

  .cta-btn:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 0 60px rgba(0,229,160,0.5);
  }

  @keyframes pulse-glow {
    0%,100% { box-shadow: 0 0 40px rgba(0,229,160,0.3); }
    50%      { box-shadow: 0 0 60px rgba(0,229,160,0.55); }
  }

  .stats-row {
    display: flex;
    gap: 40px;
    margin-top: 60px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .stat { text-align: center; }

  .stat-num {
    font-family: 'Inter', sans-serif;
    font-size: 32px;
    font-weight: 900;
    color: var(--accent);
  }
  html[dir="rtl"] .stat-num { font-family: 'Tajawal', sans-serif; }

  .stat-label { font-size: 13px; color: var(--muted); margin-top: 4px; }

  /* ===== FORM SECTION ===== */
  .form-section {
    display: none;
    position: relative;
    z-index: 1;
    padding: 60px 20px;
    max-width: 760px;
    margin: 0 auto;
    animation: slideUp 0.6s ease;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .section-title {
    font-family: 'Inter', sans-serif;
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 800;
    text-align: center;
    margin-bottom: 10px;
  }
  html[dir="rtl"] .section-title { font-family: 'Tajawal', sans-serif; }

  .section-sub {
    text-align: center;
    color: var(--muted);
    margin-bottom: 40px;
    font-size: 15px;
  }

  /* Goal Cards */
  .goal-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  .goal-card {
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 20px;
    padding: 28px 20px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .goal-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .goal-card.lose::before  { background: linear-gradient(135deg, rgba(0,229,160,0.08), transparent); }
  .goal-card.gain::before  { background: linear-gradient(135deg, rgba(255,107,53,0.08), transparent); }
  .goal-card.tone::before  { background: linear-gradient(135deg, rgba(0,151,255,0.08), transparent); }
  .goal-card.maint::before { background: linear-gradient(135deg, rgba(255,215,0,0.08), transparent); }

  .goal-card:hover,
  .goal-card.active {
    border-color: var(--accent);
    transform: translateY(-4px);
  }

  .goal-card:hover::before,
  .goal-card.active::before { opacity: 1; }

  .goal-card.gain.active  { border-color: var(--accent3); }
  .goal-card.tone.active  { border-color: var(--accent2); }
  .goal-card.maint.active { border-color: var(--gold); }

  .goal-icon { font-size: 40px; margin-bottom: 12px; }
  .goal-name { font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 700; }
  html[dir="rtl"] .goal-name { font-family: 'Tajawal', sans-serif; }
  .goal-desc { font-size: 12px; color: var(--muted); margin-top: 6px; }

  /* Inputs grid */
  .inputs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .input-group label {
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: 0.5px;
  }

  .input-group input,
  .input-group select {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 14px 18px;
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    outline: none;
    transition: border-color 0.2s;
  }
  html[dir="rtl"] .input-group input,
  html[dir="rtl"] .input-group select { font-family: 'Tajawal', sans-serif; }

  .input-group input:focus,
  .input-group select:focus { border-color: var(--accent); }

  .input-group select option { background: var(--surface); }

  /* Activity selector */
  .activity-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 28px;
  }

  .act-btn {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 14px 8px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
    color: var(--text);
  }
  html[dir="rtl"] .act-btn { font-family: 'Tajawal', sans-serif; }

  .act-btn .act-icon { font-size: 22px; display: block; margin-bottom: 6px; }
  .act-btn .act-name { font-size: 11px; font-weight: 600; color: var(--muted); }

  .act-btn:hover, .act-btn.active {
    border-color: var(--accent2);
    background: rgba(0,151,255,0.08);
  }

  .act-btn.active .act-name { color: var(--accent2); }

  /* Days-per-week pills */
  .days-input-wrap {
    display: flex;
    align-items: center;
    gap: 18px;
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 16px;
    padding: 18px 24px;
    margin-bottom: 28px;
    transition: border-color 0.2s;
  }
  .days-input-wrap:focus-within { border-color: var(--accent3); }
  .days-input-icon { font-size: 30px; }
  .days-input-text { flex: 1; }
  .days-input-title { font-size: 15px; font-weight: 700; margin-bottom: 3px; }
  .days-input-sub { font-size: 12px; color: var(--muted); }
  .days-number-input {
    background: var(--surface);
    border: 2px solid var(--accent3);
    border-radius: 12px;
    color: var(--accent3);
    font-family: 'Inter', sans-serif;
    font-size: 28px;
    font-weight: 900;
    width: 72px;
    height: 64px;
    text-align: center;
    outline: none;
    transition: all 0.2s;
  }
  .days-number-input:focus { box-shadow: 0 0 0 3px rgba(255,107,53,0.25); }
  html[dir="rtl"] .days-number-input { font-family: 'Tajawal', sans-serif; }

  /* Food preference chips */
  .chip-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 28px;
  }

  .chip {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 50px;
    padding: 10px 20px;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .chip:hover { border-color: var(--accent); }
  .chip.active {
    border-color: var(--accent);
    background: rgba(0,229,160,0.1);
    color: var(--accent);
  }

  /* Generate button */
  .gen-btn {
    width: 100%;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #000;
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 800;
    border: none;
    padding: 20px;
    border-radius: 16px;
    cursor: pointer;
    transition: all 0.3s;
    letter-spacing: 0.5px;
  }
  html[dir="rtl"] .gen-btn { font-family: 'Tajawal', sans-serif; }

  .gen-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 40px rgba(0,229,160,0.4);
  }

  .gen-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  /* ===== RESULTS ===== */
  .results-section {
    display: none;
    position: relative;
    z-index: 1;
    padding: 60px 20px;
    max-width: 900px;
    margin: 0 auto;
    animation: slideUp 0.6s ease;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-bottom: 40px;
  }

  .sum-card {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 18px;
    padding: 22px 16px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .sum-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent);
  }

  .sum-card:nth-child(2)::after { background: var(--accent2); }
  .sum-card:nth-child(3)::after { background: var(--accent3); }
  .sum-card:nth-child(4)::after { background: var(--gold); }

  .sum-val {
    font-family: 'Inter', sans-serif;
    font-size: 28px;
    font-weight: 900;
    color: var(--accent);
    display: block;
  }
  html[dir="rtl"] .sum-val { font-family: 'Tajawal', sans-serif; }

  .sum-card:nth-child(2) .sum-val { color: var(--accent2); }
  .sum-card:nth-child(3) .sum-val { color: var(--accent3); }
  .sum-card:nth-child(4) .sum-val { color: var(--gold); }

  .sum-label { font-size: 12px; color: var(--muted); margin-top: 6px; font-weight: 500; }

  /* Plan Tabs */
  .tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 28px;
    background: var(--card);
    padding: 8px;
    border-radius: 16px;
    border: 1px solid var(--border);
  }

  .tab {
    flex: 1;
    padding: 12px;
    border: none;
    background: transparent;
    color: var(--muted);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s;
  }
  html[dir="rtl"] .tab { font-family: 'Tajawal', sans-serif; }

  .tab.active {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #000;
  }

  .tab-content { display: none; }
  .tab-content.active { display: block; animation: fadeIn 0.4s ease; }

  @keyframes fadeIn { from { opacity:0 } to { opacity:1 } }

  .day-label {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  html[dir="rtl"] .day-label { font-family: 'Tajawal', sans-serif; }

  .day-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  .meals-grid { display: grid; gap: 14px; margin-bottom: 30px; }

  .meal-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: transform 0.2s;
  }

  html[dir="ltr"] .meal-card:hover { transform: translateX(4px); }
  html[dir="rtl"] .meal-card:hover { transform: translateX(-4px); }

  .meal-emoji { font-size: 32px; min-width: 44px; text-align: center; }

  .meal-info { flex: 1; }
  .meal-name { font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 700; margin-bottom: 4px; }
  html[dir="rtl"] .meal-name { font-family: 'Tajawal', sans-serif; }
  .meal-detail { font-size: 13px; color: var(--muted); line-height: 1.6; }

  .meal-cals { text-align: center; min-width: 70px; }

  .cal-num {
    font-family: 'Inter', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: var(--accent);
    display: block;
  }
  html[dir="rtl"] .cal-num { font-family: 'Tajawal', sans-serif; }

  .cal-label { font-size: 10px; color: var(--muted); }

  .macros-bar {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 30px;
  }

  .macros-title { font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; margin-bottom: 16px; }
  html[dir="rtl"] .macros-title { font-family: 'Tajawal', sans-serif; }

  .macro-row { margin-bottom: 12px; }
  .macro-header { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 13px; }
  .macro-name { color: var(--muted); }
  .macro-val { font-weight: 700; }

  .macro-track { height: 6px; background: var(--border); border-radius: 10px; overflow: hidden; }

  .macro-fill { height: 100%; border-radius: 10px; transition: width 1s ease; }

  .workout-day {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 18px;
    margin-bottom: 16px;
    overflow: hidden;
  }

  .workout-header {
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    border-bottom: 1px solid var(--border);
  }

  .workout-day-icon { font-size: 24px; }
  .workout-day-info { flex: 1; }
  .workout-day-name { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 700; }
  html[dir="rtl"] .workout-day-name { font-family: 'Tajawal', sans-serif; }
  .workout-day-focus { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .workout-badge {
    background: rgba(0,229,160,0.15);
    color: var(--accent);
    font-size: 11px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
    border: 1px solid rgba(0,229,160,0.3);
    white-space: nowrap;
  }

  .exercises-list { padding: 0 20px 20px; }

  .exercise-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }

  .exercise-item:last-child { border-bottom: none; }

  .ex-num {
    width: 32px; height: 32px;
    background: rgba(0,151,255,0.15);
    color: var(--accent2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 13px;
    flex-shrink: 0;
  }

  .ex-info { flex: 1; }
  .ex-name { font-weight: 600; font-size: 14px; margin-bottom: 3px; }
  .ex-detail { font-size: 12px; color: var(--muted); }
  .ex-sets {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--accent3);
    white-space: nowrap;
  }
  html[dir="rtl"] .ex-sets { font-family: 'Tajawal', sans-serif; }

  .tips-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 30px;
  }

  .tip-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .tip-icon { font-size: 28px; flex-shrink: 0; }
  .tip-text { font-size: 13px; color: var(--muted); line-height: 1.7; }
  .tip-title { font-weight: 700; color: var(--text); margin-bottom: 4px; font-size: 14px; }

  .restart-btn {
    background: transparent;
    border: 1.5px solid var(--border);
    color: var(--muted);
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    padding: 14px 36px;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.2s;
    display: block;
    margin: 30px auto 0;
  }
  html[dir="rtl"] .restart-btn { font-family: 'Tajawal', sans-serif; }

  .restart-btn:hover { border-color: var(--accent); color: var(--accent); }

  .loading-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10,14,26,0.92);
    z-index: 100;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 20px;
  }

  .loading-overlay.show { display: flex; }

  .spinner {
    width: 60px; height: 60px;
    border: 3px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .loading-text {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--accent);
  }
  html[dir="rtl"] .loading-text { font-family: 'Tajawal', sans-serif; }

  .loading-sub { font-size: 13px; color: var(--muted); }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--muted); }

  @media(max-width: 640px) {
    .goal-cards { grid-template-columns: 1fr 1fr; }
    .inputs-grid { grid-template-columns: 1fr; }
    .activity-grid { grid-template-columns: repeat(3,1fr); }

    .summary-grid { grid-template-columns: 1fr 1fr; }
    .tips-grid { grid-template-columns: 1fr; }
    .tabs { flex-wrap: wrap; }
  }
</style>
</head>
<body>

<!-- LANG TOGGLE -->
<button class="lang-toggle" id="langBtn" onclick="toggleLang()">
  🌐 <span id="langBtnText">عربي</span>
</button>

<!-- LOADING -->
<div class="loading-overlay" id="loading">
  <div class="spinner"></div>
  <div class="loading-text" id="loadingText">Analyzing your data...</div>
  <div class="loading-sub" id="loadingSub">Building your personal plan</div>
</div>

<!-- HERO -->
<section class="hero" id="heroSection">
  <div class="logo">
    <span class="logo-icon">⚡</span>
    FitPlan Pro
  </div>
  <h1 id="heroTitle">Transform Your Body<br>with Real Intelligence</h1>
  <p id="heroSub">A fully personalized nutrition and workout plan, scientifically calculated for your body and your goal.</p>
  <button class="cta-btn" id="heroCta" onclick="startJourney()">Start Your Journey →</button>
  <div class="stats-row">
    <div class="stat">
      <div class="stat-num">5</div>
      <div class="stat-label" id="stat1">Daily Meals</div>
    </div>
    <div class="stat">
      <div class="stat-num" id="statDaysNum">6</div>
      <div class="stat-label" id="stat2">Training Days</div>
    </div>
    <div class="stat">
      <div class="stat-num">100%</div>
      <div class="stat-label" id="stat3">Personalized</div>
    </div>
    <div class="stat">
      <div class="stat-num" id="stat4num">Science</div>
      <div class="stat-label" id="stat4">Based on TDEE</div>
    </div>
  </div>
</section>

<!-- FORM -->
<section class="form-section" id="formSection">
  <h2 class="section-title" id="formTitle">Tell Us About Yourself</h2>
  <p class="section-sub" id="formSub">All the info we need to calculate your plan accurately</p>

  <!-- Goal -->
  <div style="margin-bottom:28px">
    <div class="day-label" id="goalLabel">What is your goal?</div>
    <div class="goal-cards">
      <div class="goal-card lose" onclick="selectGoal('lose',this)">
        <div class="goal-icon">🔥</div>
        <div class="goal-name" id="goal1n">Weight Loss</div>
        <div class="goal-desc" id="goal1d">Burn fat while preserving muscle</div>
      </div>
      <div class="goal-card gain" onclick="selectGoal('gain',this)">
        <div class="goal-icon">💪</div>
        <div class="goal-name" id="goal2n">Weight Gain</div>
        <div class="goal-desc" id="goal2d">Build muscle mass and increase size</div>
      </div>
      <div class="goal-card tone" onclick="selectGoal('tone',this)">
        <div class="goal-icon">⚡</div>
        <div class="goal-name" id="goal3n">Body Toning</div>
        <div class="goal-desc" id="goal3d">Define muscles and burn fat together</div>
      </div>
      <div class="goal-card maint" onclick="selectGoal('maint',this)">
        <div class="goal-icon">⚖️</div>
        <div class="goal-name" id="goal4n">Maintenance</div>
        <div class="goal-desc" id="goal4d">Keep your current weight and improve health</div>
      </div>
    </div>
  </div>

  <!-- Inputs -->
  <div class="inputs-grid">
    <div class="input-group">
      <label id="lAge">Age</label>
      <input type="number" id="age" placeholder="25" min="14" max="80">
    </div>
    <div class="input-group">
      <label id="lGender">Gender</label>
      <select id="gender">
        <option value="male" id="optMale">Male</option>
        <option value="female" id="optFemale">Female</option>
      </select>
    </div>
    <div class="input-group">
      <label id="lHeight">Height (cm)</label>
      <input type="number" id="height" placeholder="175" min="140" max="220">
    </div>
    <div class="input-group">
      <label id="lWeight">Current Weight (kg)</label>
      <input type="number" id="weight" placeholder="75" min="30" max="250">
    </div>
    <div class="input-group">
      <label id="lTarget">Target Weight (kg)</label>
      <input type="number" id="targetWeight" placeholder="65" min="30" max="250">
    </div>
    <div class="input-group">
      <label id="lDuration">Duration</label>
      <select id="duration">
        <option value="4" id="optW4">4 Weeks</option>
        <option value="8" selected id="optW8">8 Weeks</option>
        <option value="12" id="optW12">12 Weeks</option>
        <option value="16" id="optW16">16 Weeks</option>
      </select>
    </div>
  </div>

  <!-- Activity -->
  <div style="margin-bottom:28px">
    <div class="day-label" id="actLabel">Your Daily Activity Level</div>
    <div class="activity-grid">
      <div class="act-btn" onclick="selectActivity(1.2, this)">
        <span class="act-icon">🛋️</span>
        <span class="act-name" id="act1">Sedentary</span>
      </div>
      <div class="act-btn" onclick="selectActivity(1.375, this)">
        <span class="act-icon">🚶</span>
        <span class="act-name" id="act2">Light</span>
      </div>
      <div class="act-btn active" onclick="selectActivity(1.55, this)">
        <span class="act-icon">🏃</span>
        <span class="act-name" id="act3">Moderate</span>
      </div>
      <div class="act-btn" onclick="selectActivity(1.725, this)">
        <span class="act-icon">🏋️</span>
        <span class="act-name" id="act4">Active</span>
      </div>
      <div class="act-btn" onclick="selectActivity(1.9, this)">
        <span class="act-icon">🔥</span>
        <span class="act-name" id="act5">Very Active</span>
      </div>
      <div class="act-btn" onclick="selectActivity(1.0, this)">
        <span class="act-icon">👶</span>
        <span class="act-name" id="act6">Almost None</span>
      </div>
    </div>
  </div>

  <!-- Training days per week -->
  <div style="margin-bottom:28px">
    <div class="day-label" id="daysLabel">How many days a week do you want to train?</div>
    <div class="days-input-wrap">
      <span class="days-input-icon">📅</span>
      <div class="days-input-text">
        <div class="days-input-title" id="daysInputTitle">Training days per week</div>
        <div class="days-input-sub" id="daysInputSub">Enter any number from 1 to 7</div>
      </div>
      <input class="days-number-input" type="number" id="daysInput" value="5" min="1" max="7"
        oninput="onDaysInput(this)">
    </div>
  </div>

  <!-- Food preferences -->
  <div style="margin-bottom:28px">
    <div class="day-label" id="foodPrefLabel">Any food preferences?</div>
    <div class="chip-grid" id="foodPrefGrid">
      <div class="chip active" data-val="none" onclick="toggleFoodPref('none', this)">🍽️ <span id="fp0">No restrictions</span></div>
      <div class="chip" data-val="vegetarian" onclick="toggleFoodPref('vegetarian', this)">🥦 <span id="fp1">Vegetarian</span></div>
      <div class="chip" data-val="nodairy" onclick="toggleFoodPref('nodairy', this)">🚫🥛 <span id="fp2">No dairy</span></div>
      <div class="chip" data-val="nofish" onclick="toggleFoodPref('nofish', this)">🚫🐟 <span id="fp3">No fish/seafood</span></div>
      <div class="chip" data-val="nored" onclick="toggleFoodPref('nored', this)">🚫🥩 <span id="fp4">No red meat</span></div>
      <div class="chip" data-val="lowcarb" onclick="toggleFoodPref('lowcarb', this)">🥑 <span id="fp5">Low carb</span></div>
    </div>
  </div>

  <button class="gen-btn" id="genBtn" onclick="generatePlan()">
    ✨ Generate My Personal Plan
  </button>
  <button class="restart-btn" id="backBtn" onclick="goBack()">← Back</button>
</section>

<!-- RESULTS -->
<section class="results-section" id="resultsSection">
  <div style="text-align:center;margin-bottom:40px">
    <div class="logo" style="justify-content:center" id="myPlanLabel">⚡ Your Personal Plan</div>
    <h2 class="section-title" id="resultTitle">Weight Loss Program</h2>
    <p class="section-sub" id="resultSub">Personalized based on your body data</p>
  </div>

  <!-- Summary -->
  <div class="summary-grid" id="summaryGrid">
    <div class="sum-card">
      <span class="sum-val" id="s1">0</span>
      <div class="sum-label" id="sum1Label">Daily Calories (kcal)</div>
    </div>
    <div class="sum-card">
      <span class="sum-val" id="s2">0</span>
      <div class="sum-label" id="sum2Label">Daily Protein (g)</div>
    </div>
    <div class="sum-card">
      <span class="sum-val" id="s3">0</span>
      <div class="sum-label" id="sum3Label">Current BMI</div>
    </div>
    <div class="sum-card">
      <span class="sum-val" id="s4">0</span>
      <div class="sum-label" id="sum4Label">Time to Goal</div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="tabs">
    <button class="tab active" id="tabNutBtn" onclick="switchTab('nutrition',this)">🥗 Nutrition</button>
    <button class="tab" id="tabWorkBtn" onclick="switchTab('workout',this)">🏋️ Workout</button>
    <button class="tab" id="tabTipsBtn" onclick="switchTab('tips',this)">💡 Tips</button>
  </div>

  <!-- NUTRITION TAB -->
  <div class="tab-content active" id="tab-nutrition">
    <div class="macros-bar">
      <div class="macros-title" id="macrosTitle">🎯 Macronutrient Distribution</div>
      <div class="macro-row">
        <div class="macro-header">
          <span class="macro-name" id="macroPLabel">Protein</span>
          <span class="macro-val" id="m-protein" style="color:var(--accent)">0g</span>
        </div>
        <div class="macro-track"><div class="macro-fill" id="mf-protein" style="width:0%;background:var(--accent)"></div></div>
      </div>
      <div class="macro-row">
        <div class="macro-header">
          <span class="macro-name" id="macroCLabel">Carbohydrates</span>
          <span class="macro-val" id="m-carbs" style="color:var(--accent2)">0g</span>
        </div>
        <div class="macro-track"><div class="macro-fill" id="mf-carbs" style="width:0%;background:var(--accent2)"></div></div>
      </div>
      <div class="macro-row">
        <div class="macro-header">
          <span class="macro-name" id="macroFLabel">Fats</span>
          <span class="macro-val" id="m-fat" style="color:var(--accent3)">0g</span>
        </div>
        <div class="macro-track"><div class="macro-fill" id="mf-fat" style="width:0%;background:var(--accent3)"></div></div>
      </div>
    </div>

    <div id="mealsContainer"></div>
  </div>

  <!-- WORKOUT TAB -->
  <div class="tab-content" id="tab-workout">
    <div id="workoutContainer"></div>
  </div>

  <!-- TIPS TAB -->
  <div class="tab-content" id="tab-tips">
    <div class="tips-grid" id="tipsContainer"></div>
  </div>

  <button class="restart-btn" id="restartBtn" onclick="restart()">🔄 Recalculate</button>
</section>

<script>
  let selectedGoal = null;
  let activityFactor = 1.55;
  let selectedDays = 5;
  let selectedFoodPrefs = ['none'];
  let currentLang = 'en';

  function startJourney() {
    document.getElementById('heroSection').style.display = 'none';
    document.getElementById('formSection').style.display = 'block';
    window.scrollTo(0,0);
  }

  function goBack() {
    document.getElementById('formSection').style.display = 'none';
    document.getElementById('heroSection').style.display = 'flex';
    window.scrollTo(0,0);
  }

  function restart() {
    document.getElementById('resultsSection').style.display = 'none';
    document.getElementById('heroSection').style.display = 'flex';
    window.scrollTo(0,0);
  }

  function selectGoal(goal, el) {
    document.querySelectorAll('.goal-card').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    selectedGoal = goal;
  }

  function selectActivity(factor, el) {
    document.querySelectorAll('.act-btn').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
    activityFactor = factor;
  }

  function onDaysInput(input) {
    let val = parseInt(input.value);
    if (isNaN(val) || val < 1) val = 1;
    if (val > 7) val = 7;
    input.value = val;
    selectedDays = val;
    document.getElementById('statDaysNum').textContent = val;
  }

  function toggleFoodPref(val, el) {
    if (val === 'none') {
      selectedFoodPrefs = ['none'];
      document.querySelectorAll('#foodPrefGrid .chip').forEach(c => c.classList.remove('active'));
      el.classList.add('active');
      return;
    }
    // remove "none" if selecting a real restriction
    const noneChip = document.querySelector('#foodPrefGrid .chip[data-val="none"]');
    selectedFoodPrefs = selectedFoodPrefs.filter(v => v !== 'none');
    noneChip.classList.remove('active');

    if (selectedFoodPrefs.includes(val)) {
      selectedFoodPrefs = selectedFoodPrefs.filter(v => v !== val);
      el.classList.remove('active');
    } else {
      selectedFoodPrefs.push(val);
      el.classList.add('active');
    }

    if (selectedFoodPrefs.length === 0) {
      selectedFoodPrefs = ['none'];
      noneChip.classList.add('active');
    }
  }

  function switchTab(name, btn) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-'+name).classList.add('active');
  }

  // ===== CALCULATION ENGINE =====
  function calcBMR(weight, height, age, gender) {
    if(gender === 'male') return 10*weight + 6.25*height - 5*age + 5;
    return 10*weight + 6.25*height - 5*age - 161;
  }

  function calcTDEE(bmr, activity) { return Math.round(bmr * activity); }

  function calcBMI(weight, height) { return (weight / (height/100)**2).toFixed(1); }

  function generatePlan() {
    const age = parseInt(document.getElementById('age').value);
    const gender = document.getElementById('gender').value;
    const height = parseInt(document.getElementById('height').value);
    const weight = parseInt(document.getElementById('weight').value);
    const targetWeight = parseInt(document.getElementById('targetWeight').value);
    const duration = parseInt(document.getElementById('duration').value);

    if(!selectedGoal || !age || !height || !weight || !targetWeight) {
      alert(t[currentLang].alertMsg);
      return;
    }

    document.getElementById('loading').classList.add('show');

    setTimeout(() => {
      const bmr = calcBMR(weight, height, age, gender);
      const tdee = calcTDEE(bmr, activityFactor);
      const bmi = calcBMI(weight, height);

      let targetCals, deficit;
      if(selectedGoal === 'lose') {
        deficit = Math.min(700, Math.round((weight - targetWeight) * 7700 / (duration * 7)));
        targetCals = Math.max(1200, tdee - deficit);
      } else if(selectedGoal === 'gain') {
        deficit = -Math.min(500, Math.round((targetWeight - weight) * 7700 / (duration * 7)));
        targetCals = tdee + Math.abs(deficit);
      } else if(selectedGoal === 'tone') {
        targetCals = tdee - 300;
        deficit = 300;
      } else {
        targetCals = tdee;
        deficit = 0;
      }

      const protein = Math.round(weight * (selectedGoal === 'gain' ? 2.2 : 2.0));
      const fat = Math.round(targetCals * 0.25 / 9);
      const carbs = Math.round((targetCals - protein*4 - fat*9) / 4);

      const weightDiff = Math.abs(targetWeight - weight);
      const weeklyChange = Math.abs(deficit) * 7 / 7700;
      const weeksNeeded = weeklyChange > 0 ? Math.round(weightDiff / weeklyChange) : duration;

      document.getElementById('loading').classList.remove('show');
      document.getElementById('formSection').style.display = 'none';
      document.getElementById('resultsSection').style.display = 'block';
      window.scrollTo(0,0);

      renderResults(selectedGoal, targetCals, protein, carbs, fat, bmi, weeksNeeded, weight, gender, selectedDays, selectedFoodPrefs);
    }, 1800);
  }

  function renderResults(goal, cals, protein, carbs, fat, bmi, weeks, weight, gender, days, foodPrefs) {
    const l = t[currentLang];
    document.getElementById('resultTitle').textContent = l.titles[goal];
    document.getElementById('resultSub').textContent = l.subs[goal];
    document.getElementById('s1').textContent = cals.toLocaleString();
    document.getElementById('s2').textContent = protein;
    document.getElementById('s3').textContent = bmi;
    document.getElementById('s4').textContent = weeks + l.weekUnit;

    const total = protein*4 + carbs*4 + fat*9;
    document.getElementById('m-protein').textContent = protein + l.gramUnit;
    document.getElementById('m-carbs').textContent = carbs + l.gramUnit;
    document.getElementById('m-fat').textContent = fat + l.gramUnit;
    setTimeout(() => {
      document.getElementById('mf-protein').style.width = Math.round(protein*4/total*100) + '%';
      document.getElementById('mf-carbs').style.width = Math.round(carbs*4/total*100) + '%';
      document.getElementById('mf-fat').style.width = Math.round(fat*9/total*100) + '%';
    }, 300);

    renderMeals(goal, cals, protein, carbs, fat, foodPrefs);
    renderWorkout(goal, gender, days);
    renderTips(goal);
  }

  // ===== MEAL DATA (tagged by dietary attributes) =====
  // tags: veg (vegetarian-friendly), dairy, fish, redmeat, carbHeavy
  function getMealPool(lang) {
    const ar = {
      lose: [
        { t:'Breakfast', emoji:'🥚', name:'بيض مسلوق مع خبز قمح كامل', detail:'3 بيضات + شريحة خبز + طماطم + خيار', ratio:0.22, tags:['dairy_free','redmeat_free','fish_free'] },
        { t:'Snack', emoji:'🍎', name:'فاكهة وزبادي يوناني', detail:'تفاحة كبيرة + كوب زبادي قليل الدسم', ratio:0.10, tags:['veg','redmeat_free','fish_free','dairy'] },
        { t:'Lunch', emoji:'🍗', name:'صدر دجاج مشوي مع أرز بني وسلطة', detail:'200 غرام دجاج + 1 كوب أرز بني + سلطة خضراء', ratio:0.35, tags:['redmeat_free','fish_free','dairy_free'] },
        { t:'Snack', emoji:'🥜', name:'مكسرات وبروتين شيك', detail:'حفنة لوز + بروتين شيك بالماء', ratio:0.12, tags:['veg','redmeat_free','fish_free','dairy_free'] },
        { t:'Dinner', emoji:'🐟', name:'سمك مشوي مع خضروات مشوية', detail:'200 غرام سمك + كوسة + فلفل + بصل مشوي', ratio:0.21, tags:['redmeat_free','dairy_free'] }
      ],
      lose_veg: [
        { t:'Breakfast', emoji:'🥚', name:'بيض مسلوق مع خبز قمح كامل', detail:'3 بيضات + شريحة خبز + طماطم + خيار', ratio:0.22, tags:['dairy_free','redmeat_free','fish_free'] },
        { t:'Snack', emoji:'🍎', name:'فاكهة وزبادي يوناني', detail:'تفاحة كبيرة + كوب زبادي قليل الدسم', ratio:0.10, tags:['veg','dairy'] },
        { t:'Lunch', emoji:'🧆', name:'فلافل مع حمص وسلطة وأرز بني', detail:'6 حبات فلافل + حمص + 1 كوب أرز بني + سلطة', ratio:0.35, tags:['veg','dairy_free'] },
        { t:'Snack', emoji:'🥜', name:'مكسرات وبروتين شيك نباتي', detail:'حفنة لوز + بروتين شيك بالماء (نباتي)', ratio:0.12, tags:['veg','dairy_free'] },
        { t:'Dinner', emoji:'🍳', name:'توفو مشوي مع خضروات مشوية', detail:'200 غرام توفو + كوسة + فلفل + بصل مشوي', ratio:0.21, tags:['veg','dairy_free'] }
      ],
      gain: [
        { t:'Breakfast', emoji:'🥣', name:'شوفان بالموز والعسل والمكسرات', detail:'2 كوب شوفان + موزتان + ملعقة عسل + مكسرات مشكلة', ratio:0.25, tags:['veg','dairy_free'] },
        { t:'Snack', emoji:'🥛', name:'بروتين شيك مع الموز والحليب الكامل', detail:'2 مسحوق بروتين + موزة + كوب حليب كامل + زبدة فول سوداني', ratio:0.15, tags:['veg','dairy'] },
        { t:'Lunch', emoji:'🍖', name:'لحم بقري مع بطاطا مشوية وأرز', detail:'250 غرام لحم بقري + بطاطا + 1.5 كوب أرز أبيض', ratio:0.30, tags:['redmeat','dairy_free'] },
        { t:'Snack', emoji:'🧀', name:'تونة مع جبنة وخبز كامل', detail:'علبة تونة + جبنة + خبز قمح كامل', ratio:0.12, tags:['fish','dairy'] },
        { t:'Dinner', emoji:'🍗', name:'دجاج مع مكرونة وصلصة طماطم', detail:'200 غرام دجاج + كوب مكرونة + صلصة طماطم منزلية', ratio:0.18, tags:['redmeat_free','fish_free','dairy_free'] }
      ],
      gain_veg: [
        { t:'Breakfast', emoji:'🥣', name:'شوفان بالموز والعسل والمكسرات', detail:'2 كوب شوفان + موزتان + ملعقة عسل + مكسرات مشكلة', ratio:0.25, tags:['veg','dairy_free'] },
        { t:'Snack', emoji:'🥛', name:'بروتين شيك مع الموز والحليب الكامل', detail:'2 مسحوق بروتين + موزة + كوب حليب كامل + زبدة فول سوداني', ratio:0.15, tags:['veg','dairy'] },
        { t:'Lunch', emoji:'🫘', name:'عدس وأرز مع جبنة وخضروات', detail:'2 كوب عدس + 1.5 كوب أرز + جبنة + خضروات مشكلة', ratio:0.30, tags:['veg','dairy'] },
        { t:'Snack', emoji:'🧀', name:'جبنة مع خبز كامل وزيتون', detail:'جبنة + خبز قمح كامل + زيتون', ratio:0.12, tags:['veg','dairy'] },
        { t:'Dinner', emoji:'🍝', name:'توفو مع مكرونة وصلصة طماطم', detail:'200 غرام توفو + كوب مكرونة + صلصة طماطم منزلية', ratio:0.18, tags:['veg','dairy_free'] }
      ],
      tone: [
        { t:'Breakfast', emoji:'🥗', name:'سموذي خضراء مع بروتين', detail:'سبانخ + موزة + بروتين شيك + بذور شيا', ratio:0.20, tags:['veg','dairy_free'] },
        { t:'Snack', emoji:'🍳', name:'بياض البيض مع خضروات', detail:'4 بياض بيض + فلفل + بصل + بندورة', ratio:0.12, tags:['dairy_free','redmeat_free','fish_free'] },
        { t:'Lunch', emoji:'🥩', name:'صدر دجاج مع كينوا وبروكلي', detail:'200 غرام دجاج + نصف كوب كينوا + بروكلي مسلوق', ratio:0.33, tags:['redmeat_free','fish_free','dairy_free'] },
        { t:'Snack', emoji:'🫐', name:'زبادي يوناني مع توت وجوز', detail:'كوب زبادي يوناني + كوب توت + حفنة جوز', ratio:0.12, tags:['veg','dairy'] },
        { t:'Dinner', emoji:'🦐', name:'جمبري مشوي مع أسباراغس وسلطة', detail:'200 غرام جمبري + أسباراغس + سلطة روكا', ratio:0.23, tags:['fish','dairy_free'] }
      ],
