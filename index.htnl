  function toggleLang() {
    currentLang = currentLang === 'en' ? 'ar' : 'en';
    applyLang();
  }

  function applyLang() {
    const l = t[currentLang];
    const isAr = currentLang === 'ar';
    const html = document.documentElement;

    html.setAttribute('lang', currentLang);
    html.setAttribute('dir', isAr ? 'rtl' : 'ltr');
    document.title = l.pageTitle;
    document.getElementById('langBtnText').textContent = isAr ? 'EN' : 'عربي';

    document.getElementById('loadingText').textContent = l.loadingText;
    document.getElementById('loadingSub').textContent = l.loadingSub;

    document.getElementById('heroTitle').innerHTML = l.heroTitle;
    document.getElementById('heroSub').textContent = l.heroSub;
    document.getElementById('heroCta').textContent = l.heroCta;
    document.getElementById('stat1').textContent = l.stat1;
    document.getElementById('stat2').textContent = l.stat2;
    document.getElementById('stat3').textContent = l.stat3;
    document.getElementById('stat4').textContent = l.stat4;
    document.getElementById('stat4num').textContent = l.stat4num;

    document.getElementById('formTitle').textContent = l.formTitle;
    document.getElementById('formSub').textContent = l.formSub;
    document.getElementById('goalLabel').textContent = l.goalLabel;

    document.getElementById('goal1n').textContent = l.goal1n;
    document.getElementById('goal1d').textContent = l.goal1d;
    document.getElementById('goal2n').textContent = l.goal2n;
    document.getElementById('goal2d').textContent = l.goal2d;
    document.getElementById('goal3n').textContent = l.goal3n;
    document.getElementById('goal3d').textContent = l.goal3d;
    document.getElementById('goal4n').textContent = l.goal4n;
    document.getElementById('goal4d').textContent = l.goal4d;

    document.getElementById('lAge').textContent = l.lAge;
    document.getElementById('lGender').textContent = l.lGender;
    document.getElementById('lHeight').textContent = l.lHeight;
    document.getElementById('lWeight').textContent = l.lWeight;
    document.getElementById('lTarget').textContent = l.lTarget;
    document.getElementById('lDuration').textContent = l.lDuration;

    document.getElementById('optMale').textContent = l.male;
    document.getElementById('optFemale').textContent = l.female;
    document.getElementById('optW4').textContent = l.w4;
    document.getElementById('optW8').textContent = l.w8;
    document.getElementById('optW12').textContent = l.w12;
    document.getElementById('optW16').textContent = l.w16;

    document.getElementById('actLabel').textContent = l.actLabel;
    document.getElementById('act1').textContent = l.act1;
    document.getElementById('act2').textContent = l.act2;
    document.getElementById('act3').textContent = l.act3;
    document.getElementById('act4').textContent = l.act4;
    document.getElementById('act5').textContent = l.act5;
    document.getElementById('act6').textContent = l.act6;

    document.getElementById('daysLabel').textContent = l.daysLabel;
    document.getElementById('daysInputTitle').textContent = l.daysInputTitle;
    document.getElementById('daysInputSub').textContent = l.daysInputSub;

    document.getElementById('foodPrefLabel').textContent = l.foodPrefLabel;
    document.getElementById('fp0').textContent = l.fp0;
    document.getElementById('fp1').textContent = l.fp1;
    document.getElementById('fp2').textContent = l.fp2;
    document.getElementById('fp3').textContent = l.fp3;
    document.getElementById('fp4').textContent = l.fp4;
    document.getElementById('fp5').textContent = l.fp5;

    document.getElementById('genBtn').textContent = l.genBtn;
    document.getElementById('backBtn').textContent = l.backBtn;

    document.getElementById('myPlanLabel').innerHTML = l.myPlan;
    document.getElementById('sum1Label').textContent = l.sum1;
    document.getElementById('sum2Label').textContent = l.sum2;
    document.getElementById('sum3Label').textContent = l.sum3;
    document.getElementById('sum4Label').textContent = l.sum4;

    document.getElementById('tabNutBtn').textContent = l.tabNut;
    document.getElementById('tabWorkBtn').textContent = l.tabWork;
    document.getElementById('tabTipsBtn').textContent = l.tabTips;
    document.getElementById('restartBtn').textContent = l.restartBtn;

    document.getElementById('macrosTitle').textContent = l.macroTitle;
    document.getElementById('macroPLabel').textContent = l.macroP;
    document.getElementById('macroCLabel').textContent = l.macroC;
    document.getElementById('macroFLabel').textContent = l.macroF;
  }

  // Initialize default language UI (English is default, but run once to be safe)
  applyLang();
</script>
