  function renderMeals(goal, cals, protein, carbs, fat, foodPrefs) {
    const l = t[currentLang];
    const pool = getMealPool(currentLang);

    // pick vegetarian variant if requested
    const isVeg = foodPrefs.includes('vegetarian');
    let meals = isVeg ? pool[goal + '_veg'] : pool[goal];

    // filter further by other restrictions
    meals = meals.filter(m => {
      if (foodPrefs.includes('nodairy') && m.tags.includes('dairy')) return false;
      if (foodPrefs.includes('nofish') && m.tags.includes('fish')) return false;
      if (foodPrefs.includes('nored') && m.tags.includes('redmeat')) return false;
      return true;
    });

    // if filtering removed too much, fall back to base set (safety net)
    if (meals.length < 4) meals = isVeg ? pool[goal + '_veg'] : pool[goal];

    let html = `<div class="day-label">${l.dayMealLabel}</div><div class="meals-grid">`;
    meals.forEach(m => {
      const mCals = Math.round(cals * m.ratio);
      html += `
        <div class="meal-card">
          <span class="meal-emoji">${m.emoji}</span>
          <div class="meal-info">
            <div class="meal-name">${l.mealTimeNames[m.t] || m.t}: ${m.name}</div>
            <div class="meal-detail">${m.detail}</div>
          </div>
          <div class="meal-cals">
            <span class="cal-num">${mCals}</span>
            <span class="cal-label">${l.calUnit}</span>
          </div>
        </div>`;
    });
    html += '</div>';

    let lowCarbNote = '';
    if (foodPrefs.includes('lowcarb')) {
      lowCarbNote = `<br><b style="color:var(--text)">${l.lowCarbNote}</b> ${l.lowCarbVal}`;
    }

    html += `<div style="background:var(--card);border:1px solid var(--border);border-radius:16px;padding:18px;margin-bottom:20px;font-size:14px;color:var(--muted);line-height:1.9">
      <b style="color:var(--text)">${l.waterNote}</b> ${Math.round(cals / 30)} ${l.waterVal}<br>
      <b style="color:var(--text)">${l.mealTime}</b> ${l.mealTimeVal}<br>
      <b style="color:var(--text)">${l.avoid}</b> ${l.avoidVal}${lowCarbNote}
    </div>`;

    document.getElementById('mealsContainer').innerHTML = html;
  }

