        ]
      },
      en: {
        lose: [
          { icon:'🥤', t:'Water First', d:'Drink a large glass of water 20 min before each meal — naturally reduces appetite and improves digestion' },
          { icon:'⏰', t:'Meal Timing', d:'Never skip breakfast. Eat it within an hour of waking up to boost your metabolism' },
          { icon:'😴', t:'Get Enough Sleep', d:'7-9 hours of sleep daily is essential — lack of sleep raises cortisol and makes weight loss harder' },
